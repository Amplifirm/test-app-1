# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit real keys.

# ── Backend API (existing) ──────────────────────────────────────────
# The Vercel-hosted personalization API. Point at local IP for dev backend.
EXPO_PUBLIC_API_BASE=https://hustleai-zeta.vercel.app

# ── Supabase (Phase 2) ───────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (for edge functions): SUPABASE_SERVICE_ROLE_KEY (NEVER ship to client)

# ── RevenueCat (Phase 4) ─────────────────────────────────────────────
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# ── Superwall (Phase 4) ──────────────────────────────────────────────
EXPO_PUBLIC_SUPERWALL_KEY=

# ── PostHog (Phase 8) ────────────────────────────────────────────────
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Sentry (Phase 8) ─────────────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=

# ── Server-side only (set in Supabase Functions secrets, never on client) ──
# RESEND_API_KEY=
# OPENAI_API_KEY=
